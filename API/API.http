########################################
# 5. SUBSKRYPCJE
########################################

### 5.1 Subskrypcja na TestMax dla Jana (ClientId=1, SoftwareId=2)
# Jan jest teraz "returning client" (ma Signed kontrakt) → +5% loyalty
# BasePrice=3000, okres=6 mcy → 3000*6 = 18000
# Zniżka "Rabat na test" 15% + loyalty 5% = 20%
# Pierwsza płatność: 18000 - 18000*0.20 = 14400
# Cena odnowienia (tylko loyalty): 18000 - 18000*0.05 = 17100
POST {{API_HostAddress}}/api/subscriptions/create-Subscription
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "TestMax Półroczna",
  "periodInMonths": 6,
  "price": 199.99,
  "softwareId": 2,
  "clientId": 1
}

### 5.2 Subskrypcja na System Pro dla MegaSoft (ClientId=4, SoftwareId=1)
# Nowy klient, brak loyalty
# BasePrice=5000, okres=12 mcy → 5000*12 = 60000
# Zniżka letnia 10%
# Pierwsza płatność: 60000 - 60000*0.10 = 54000
# Cena odnowienia: 60000
POST {{API_HostAddress}}/api/subscriptions/create-Subscription
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "System Pro Roczna",
  "periodInMonths": 12,
  "price": 499.99,
  "softwareId": 1,
  "clientId": 4
}

### 5.3 Błąd - duplikat (klient 1 ma już subskrypcję na software 2)
# (jeśli serwis to sprawdza)
POST {{API_HostAddress}}/api/subscriptions/create-Subscription
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Duplikat",
  "periodInMonths": 1,
  "price": 100,
  "softwareId": 2,
  "clientId": 1
}


